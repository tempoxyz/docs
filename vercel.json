      "permanent": true
    },
    {
      "source": "/learn/stablecoins",
      "destination": "https://tempo.xyz/learn/what-are-stablecoins",
      "permanent": true
    },
    {
      "source": "/learn/use-cases/global-payouts",
      "destination": "https://tempo.xyz/learn/global-payouts",
