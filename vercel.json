{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "docs.tempo.xyz"
        }
      ],
      "destination": "https://tempo.xyz/developers",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "docs.tempo.xyz"
        }
      ],
      "destination": "https://tempo.xyz/developers/:path*",
      "permanent": true
    },
    {
