    "anser": "^2.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "use-sync-external-store": "^1.6.0",
    "vite": "^8.0.16",
    "vite-plugin-mkcert": "^1.17.12"
